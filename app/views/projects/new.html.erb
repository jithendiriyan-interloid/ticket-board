<div class="w-[50%] mx-auto px-4 sm:px-6 mt-20">
  <!-- Header -->
  <div class="mb-8 border-b border-gray-100 pb-5">
    <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Create Project</h1>
    <p class="mt-2 text-sm text-gray-500">Set up a new space to organize your boards, tasks, and team collaboration.</p>
  </div>
  <!-- Global Errors -->
  <% if @project.errors.any? %>
    <div data-turbo-temporary data-controller="flash" class="fixed top-16 right-6 z-50 max-w-md rounded-xl border border-red-200 bg-red-50 p-4 shadow-xl transition-all duration-300" role="alert">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 text-red-500">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <p class="mt-1 text-sm text-red-700"><%= @project.errors.full_messages.to_sentence %></p>
        </div>
      </div>
    </div>
  <% end %>
  <!-- Empty Workspace Guard Warning -->
  <% if @workspaces.empty? %>
    <div class="mb-6 flex gap-3 rounded-xl border border-amber-200 bg-amber-50/70 p-4 text-sm text-amber-800 shadow-sm animate-pulse">
      <svg class="h-5 w-5 flex-shrink-0 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <div>
        <span class="font-semibold block mb-0.5">Workspace required</span>
        <span>You need to create a workspace before you can house a project.</span>
      </div>
    </div>
  <% end %>
  <!-- Form Container Card -->
  <%= form_with model: @project, class: "space-y-6" do |f| %>
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm <%= 'opacity-50 pointer-events-none' if @workspaces.empty? %> transition-opacity duration-200">
      <h2 class="text-base font-semibold text-gray-900 mb-5 pb-3 border-b border-gray-100">Project Details</h2>
      <div class="space-y-5">
        <!-- Project Name -->
        <div>
          <%= f.label :name, "Project Name", class: "block text-sm font-medium mb-2" %>
          <%= f.text_field :name, placeholder: "e.g., Project Alpha, Q3 Roadmap", class: "w-full  h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <!-- Description -->
        <div>
          <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium mb-2" %>
          <%= f.text_area :description, rows: 4, placeholder: "Description", class: "w-full h-[50px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <!-- Workspace Parent Assignment -->
        <div>
          <%= f.label :workspace_id, "Assign to Workspace", class: "block text-sm font-medium mb-2" %>
          <%= f.collection_select :workspace_id, @workspaces, :id, :name, { prompt: "Select a workspace..." }, { class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" } %>
        </div>
      </div>
    </div>
    <!-- Action Buttons Group -->
    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to "Cancel", :back, class: "text-sm font-semibold text-gray-700 hover:text-gray-900 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors" %>
      <%= f.submit "Create Project", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm px-5 py-2.5 rounded-lg shadow-sm disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed transition-all", disabled: @workspaces.empty? %>
    </div>
  <% end %>
</div>