<turbo-frame id="modal">
  <div data-controller="modal" data-modal-target="container" data-action="click->modal#backdropClose" class="fixed inset-0 z-[100] overflow-y-auto bg-slate-900/50 px-4 py-8 sm:px-6">
    <div class="mx-auto mt-8 w-[60%] rounded-2xl bg-slate-50 px-4 py-6 shadow-2xl sm:mt-12 sm:px-6">
      <!-- Header -->
      <div class="mb-8 flex items-start justify-between gap-4 border-b border-gray-200 pb-5">
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Edit Project</h1>
          <p class="mt-2 text-sm text-gray-500">Update your project name, description or workspace.</p>
        </div>
        <%= button_tag type: "button", data: { action: "click->modal#close" }, class: "rounded-full p-2 text-slate-500 transition hover:bg-slate-200 hover:text-slate-900" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>

      <!-- Global Errors -->
      <% if @project.errors.any? %>
        <div data-turbo-temporary data-controller="flash" class="fixed top-16 right-6 z-50 max-w-md rounded-xl border border-red-200 bg-red-50 p-4 shadow-xl transition-all duration-300" role="alert">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-red-500">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div>
              <p class="mt-1 text-sm text-red-700"><%= @project.errors.full_messages.to_sentence %></p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Form -->
      <%= form_with model: @project, data: { turbo_frame: "_top" }, class: "space-y-6" do |f| %>
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-opacity duration-200">
          <h2 class="text-base font-semibold text-gray-900 mb-5 pb-3 border-b border-gray-100">Project Details</h2>
          <div class="space-y-5">
            <!-- Project Name -->
            <div>
              <%= f.label :name, "Project Name", class: "block text-sm font-medium mb-2" %>
              <%= f.text_field :name, placeholder: "e.g., Project Alpha, Q3 Roadmap", class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
            </div>
            <!-- Description -->
            <div>
              <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium mb-2" %>
              <%= f.text_area :description, rows: 4, placeholder: "Description", class: "w-full h-[50px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
            </div>
            <!-- Workspace -->
            <div>
              <%= f.label :workspace_id, "Assign to Workspace", class: "block text-sm font-medium mb-2" %>
              <%= f.collection_select :workspace_id, @workspaces, :id, :name, { prompt: "Select a workspace..." }, { class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" } %>
            </div>
          </div>
        </div>
        <!-- Action Buttons -->
        <div class="flex items-center justify-end gap-3 pt-2">
          <%= button_tag "Cancel", type: "button", data: { action: "click->modal#close" }, class: "text-sm font-semibold hover:text-gray-900 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors" %>
          <%= f.submit "Save Changes", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm px-5 py-2.5 rounded-lg shadow-sm transition-all cursor-pointer" %>
        </div>
      <% end %>

    </div>
  </div>
</turbo-frame>