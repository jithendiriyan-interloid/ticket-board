<div class="mt-16 bg-gray-50">
  <div class="w-[55%] flex flex-col mx-auto space-y-4">
    <div class="flex-1 py-12">
      <div class="mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Your Details</h2>
        <p class="text-gray-500 text-md">Manage your personal information and account security.</p>
      </div>
      <section class="bg-white rounded-sm shadow-md border border-gray-200 p-8 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-5">Personal Details</h3>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-3">
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">First Name</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.first_name %></p>
            </div>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">LAST Name</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.last_name %></p>
            </div>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">EMAIL</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.email %></p>
            </div>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">PHONE</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.phone %></p>
            </div>
          </div>
        </div>
      </section>
      <section class="bg-white rounded-sm shadow-md border border-gray-200 p-8 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-5">Address Details</h3>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-3">
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">First Name</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.street.presence %></p>
            </div>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">LAST Name</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.city.presence %></p>
            </div>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-gray-500 font-semibold mb-1">STATE</span>
            <div class="border border-gray-200 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-900"><%= @user.state.presence %></p>
            </div>
          </div>
        </div>
        <div class="flex justify-end ">
          <%= link_to "Edit", edit_user_path(@user), class: "bg-blue-600 hover:bg-blue-700 text-white px-7 py-3 rounded-md shadow-md text-sm font-medium shadow" %>
        </div>
      </section>
      <section class="bg-white rounded-sm shadow-md border border-red-200 p-8 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-5">
          Danger Zone
        </h3>
        <p class="text-sm text-gray-500 mb-8">
          Deleting your account is permanent. All your data, projects,
          and insights will be removed instantly.
        </p>
        <%= link_to "Delete my account", user_path(@user),data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete your account?" }, class:"bg-red-600 hover:bg-red-700 text-white px-8 py-3 rounded-md text-sm font-medium shadow" %>
      </div>
    </section>
  </div>
</div>
