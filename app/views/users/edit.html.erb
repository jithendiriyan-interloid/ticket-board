<%= form_with model: @user, method: :patch, html: { multipart: true }, class: "mt-16 bg-gray-50" do |f| %>
  <div class="w-[55%] flex flex-col mx-auto space-y-4">
    <div class="flex-1 py-12">
      <div class="mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Account Settings</h2>
        <p class="text-gray-500 text-md">Manage your personal information and account security.</p>
      </div>
      <section class="bg-white rounded-sm shadow-md border border-gray-200 p-8 mb-8">
        <h3 class="text-3xl font-semibold text-gray-900 mb-6">Profile Picture</h3>
        <div class="flex items-center gap-6">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "w-24 h-24 rounded-lg object-cover border-2 border-gray-300" %>
          <% else %>
            <%= image_tag "default_avatar.jpg", class: "w-24 h-24 rounded-lg object-cover border-2 border-gray-300" %>
          <% end %>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <label class="cursor-pointer bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium shadow transition">
                <span>Upload New</span>
                <%= f.file_field :avatar, accept: ".jpg,.jpeg,.png,.gif,.webp", class: "hidden" %>
              </label>
              <% if @user.avatar.attached? %>
                <label class="flex items-center gap-2 cursor-pointer border border-gray-300 hover:bg-gray-100 text-gray-700 px-4 py-2 rounded-md text-sm font-medium transition">
                  <%= check_box_tag :remove_avatar, "1", false, class: "hidden peer" %>
                  <span>Remove</span>
                </label>
              <% end %>
            </div>
            <p class="text-sm text-gray-500">JPG, GIF, PNG or WEBP. Max size 800KB.</p>
          </div>
        </div>
      </section>
      <section class="bg-white rounded-sm shadow-md border border-gray-200 p-8 mb-8">
        <h3 class="text-3xl font-semibold text-gray-900 mb-6">Personal Details </h3>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-x-4 gap-y-4 mb-6">
          <div class="relative">
            <%= f.label :first_name, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.text_field :first_name, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :last_name, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.text_field :last_name, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :email, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.email_field :email, value: current_user&.email, readonly: true, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :phone, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.telephone_field :phone, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
        </div>
      </section>
      <section class="bg-white rounded-sm shadow-md border border-gray-200 p-4 mb-6">
        <h3 class="text-3xl font-semibold text-gray-900 mb-8">Address Details </h3>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-x-4 gap-y-4 mb-3">
          <div class="relative">
            <%= f.label :street, class:"block text-xs uppercase tracking-widest text-gray-500  mb-2 font-semibold" %>
            <%= f.text_field :street, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :city, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.text_field :city, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :state, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.text_field :state, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          </div>
          <div class="relative">
            <%= f.label :pincode, class:"block text-xs uppercase tracking-widest text-gray-500 mb-2 font-semibold" %>
            <%= f.number_field :pincode, class: "w-full border border-gray-300 rounded-md px-4 py-2 text-gray-700 focus:ring-2 focus:ring-blue-500 focus:outline-none no-spinner" %>
          </div>
        </div>
        <div class="flex justify-end ">
          <%= f.submit "Save changes", class: "bg-blue-600 hover:bg-blue-700 text-white px-7 py-3 rounded-md shadow-md text-sm font-medium shadow" %>
        </div>
      </section>
    </div>
  </div>
<% end %>