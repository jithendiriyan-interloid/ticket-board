<%= form_with model: @user, method: :patch, html: { multipart: true }, class: "mt-36" do |f| %>
  <div class="max-w-4xl mx-auto space-y-4">
    <div class="bg-white border border rounded-xl p-6">
      <p class="text-xs font-medium uppercase tracking-widest  mb-4">Profile photo</p>
      <div class="flex items-center gap-5">
        <div class="relative w-18 h-18 shrink-0">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "w-18 h-18 rounded-full object-cover border-2 border" %>
          <% else %>
            <%= image_tag "default_avatar.jpg", class: "w-18 h-18 rounded-full object-cover border-2 border" %>
          <% end %>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-800"><%= current_user.first_name %> <%= current_user.last_name %></p>
          <p class="text-xs  mb-3"><%= current_user.email %></p>
          <div class="flex items-center gap-2">
            <label class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border rounded-md bg-slate-50 hover:bg-slate-100 cursor-pointer transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>Upload photo
              <%= f.file_field :avatar, accept: ".jpg,.jpeg,.png,.webp", class: "hidden" %>
            </label>
            <% if @user.avatar.attached? %>
              <label class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium border border-red-300 text-red-600 rounded-md hover:bg-red-50 cursor-pointer transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>Remove
                <%= f.check_box :remove_avatar, { class: "hidden" }, "1", "0" %>
              </label>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-white border border rounded-xl p-6">
      <p class="text-xs font-medium uppercase tracking-widest  mb-5">Personal information</p>
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-x-7 gap-y-8 mb-6">
        <div class="relative">
          <%= f.label :first_name, "First name", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.text_field :first_name, required: true, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
        <div class="relative">
          <%= f.label :last_name, "Last name", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.text_field :last_name, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
        <div class="relative">
          <%= f.label :email, "Email address", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.email_field :email, value: current_user&.email, readonly: true, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border  cursor-not-allowed outline-none" %>
        </div>
        <div class="relative">
          <%= f.label :phone, "Phone number", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.telephone_field :phone, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
      </div>
      <p class="text-xs font-medium uppercase tracking-widest  mb-5">Address</p>
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-x-7 gap-y-8">
        <div class="relative">
          <%= f.label :street, "Street", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.text_field :street, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
        <div class="relative">
          <%= f.label :city, "City", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.text_field :city, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
        <div class="relative">
          <%= f.label :state, "State", class: "absolute -top-2 left-3 bg-white px-1.5 text-xs font-medium " %>
          <%= f.text_field :state, class: "block w-full px-4 py-3 text-sm bg-transparent rounded-md border focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none" %>
        </div>
      </div>
      <div class="flex justify-end mt-6 pt-5">
        <%= f.submit "Save changes", class: "py-2 px-4 text-sm rounded-md font-medium cursor-pointer text-white bg-blue-600 hover:bg-blue-700 transition-all" %>
      </div>
    </div>
  </div>
<% end %>

<% if @users.present? %>
  <div class="max-w-4xl mx-auto mt-8 ">
    <div class="mb-4">
      <h2 class="text-xl font-semibold">User List</h2>
      <p class="text-sm mt-1"> <%= @users.count %> total users</p>
    </div>
    <div class="overflow-x-auto bg-white border border-slate-200 rounded-xl shadow-sm">
      <table class="min-w-full">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="px-6 py-4 text-left text-sm font-semibold"> Name </th>
            <th class="px-6 py-4 text-center text-sm font-semibold"> Email </th>
            <th class="px-6 py-4  text-sm font-semibold"> Role </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @users.each do |u| %>
            <tr class="hover:bg-slate-50 transition">
              <td class="px-6 py-4 text-sm font-medium"><%= u.first_name %> </td>
              <td class="px-6 py-4 text-center text-sm"> <%= u.email %></td>
              <td class="px-6 py-4">
                <% if current_user.owner? %>
                  <%= form_with model: u, url: user_path(u), method: :patch, local: true do |f| %>
                    <div class="flex justify-end gap-2">
                      <%= f.select :role, User.roles.keys.map { |role| [role.titleize, role] },{}, class: "px-2 py-2 text-sm border rounded-md" %>
                      <%= f.submit "Save", data: { turbo_confirm: "Are you sure you want to change the role?" }, class: "px-3 py-2 text-sm bg-blue-600 text-white rounded-md" %>
                    </div>
                  <% end %>
                <% else %>
                  <span class="px-3 py-1 text-xs font-medium rounded-full
                    <%= u.role.titleize %>
                  </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
