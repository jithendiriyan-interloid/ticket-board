<turbo-frame id="modal">
  <div data-controller="modal" data-modal-target="container" data-action="click->modal#backdropClose" class="fixed inset-0 z-[100] overflow-y-auto bg-slate-900/50 px-4 py-8 sm:px-6">
    <div class="mx-auto mt-8 w-[60%]  rounded-2xl bg-slate-50 px-4 py-6 shadow-2xl sm:mt-12 sm:px-6">
      <!-- Header -->
      <div class="mb-8 flex items-start justify-between gap-4 border-b border-gray-200 pb-5">
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Create Task</h1>
          <p class="mt-2 text-sm text-gray-500">Fill in the details below to create a new task for your team.</p>
        </div>
        <%= button_tag type: "button", data: { action: "click->modal#close" }, class: "rounded-full p-2 text-slate-500 transition hover:bg-slate-200 hover:text-slate-900" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
      <!-- Global Errors (Fixed Syntax) -->
      <% if @task.errors.any? %>
        <div data-turbo-temporary data-controller="flash" class="fixed top-16 right-6 z-50 max-w-md rounded-xl border border-red-200 bg-red-50 p-4 shadow-xl transition-all duration-300" role="alert">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-red-500">
            </div>
            <div>
              <p class="mt-1 text-sm text-red-700"><%= @task.errors.full_messages.to_sentence %></p>
            </div>
          </div>
        </div>
      <% end %>
      <div class="space-y-6">
        <!-- Step 1: Board Selection -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <%= form_with url: new_task_path, method: :get, scope: :task, class: "space-y-4" do |f| %>
            <div>
              <%= f.label :board_id, "Target Board", class: "block text-sm font-semibold mb-2" %>
              <%= f.collection_select :board_id, @boards, :id, :name, 
              { prompt: "Select a board " }, 
              { class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", onchange: "this.form.requestSubmit()" } %>
            </div>
          <% end %>
          <% if @selected_board.blank? %>
            <div class="mt-4 flex gap-3 rounded-lg border border-amber-100 bg-amber-50/60 p-3.5 text-sm text-amber-800">
              <svg class="h-5 w-5 flex-shrink-0 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
              <span>Select a board first to unlock statuses and matching project details.</span>
            </div>
          <% end %>
        </div>
        <!-- Step 2: Task Form Details -->
        <%= form_with model: @task, class: "space-y-6" do |f| %>
          <%= f.hidden_field :board_id, value: @selected_board&.id %>
          <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm <%= 'opacity-50 pointer-events-none' if @selected_board.blank? %> transition-opacity duration-200">
            <h2 class="text-base font-semibold text-gray-900 mb-5 pb-3 border-b border-gray-100">Task Information</h2>
            <div class="grid gap-5 md:grid-cols-6">
              <!-- Title -->
              <div class="md:col-span-6">
                <%= f.label :title, "Task Title", class: "block text-sm font-medium mb-2" %>
                <%= f.text_field :title, placeholder: "e.g., Implement OAuth Authentication", class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <!-- Description -->
              <div class="md:col-span-6">
                <%= f.label :description, class: "block text-sm font-medium mb-2" %>
                <%= f.text_area :description, rows: 4, placeholder: "Describe the scope, goals, or acceptance criteria...", class: "h-[70px] px-2 w-full rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <!-- Metadata Grid Groupings -->
              <div class="md:col-span-3">
                <%= f.label :status_id, "Status", class: "block text-sm font-medium mb-2" %>
                <%= f.collection_select :status_id, @available_statuses || [], :id, :name, {}, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <div class="md:col-span-3 ">
                <%= f.label :task_type_id, "Task Type", class: "block text-sm font-medium mb-2" %>
                <%= f.collection_select :task_type_id, @task_types, :id, :name, { prompt: "Select type" }, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <div class="md:col-span-2">
                <%= f.label :label_id, "Label", class: "block text-sm font-medium my-3" %>
                <%= f.collection_select :label_id, @labels, :id, :name, { prompt: "Select label" }, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <div class="md:col-span-2">
                <%= f.label :story_point_id, "Story Points", class: "block text-sm font-medium my-3" %>
                <%= f.collection_select :story_point_id, @story_points, :id, :label, { prompt: "Estimate" }, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <div class="md:col-span-2">
                <%= f.label :assignee_id, "Assignee", class: "block text-sm font-medium my-3" %>
                <%= f.collection_select :assignee_id, @users, :id, :email, { prompt: "Unassigned" }, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
              </div>
              <!-- Dates Split -->
              <div class="md:col-span-3">
                <%= f.label :start_date, class: "block text-sm font-medium my-3" %>
                <%= f.date_field :start_date, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm text-gray-600" %>
              </div>
              <div class="md:col-span-3">
                <%= f.label :end_date, class: "block text-sm font-medium my-3" %>
                <%= f.date_field :end_date, class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm text-gray-600" %>
              </div>
            </div>
          </div>
          <!-- Action Footer -->
          <div class="flex items-center justify-end gap-3 pt-4">
            <%= button_tag "Cancel", type: "button", data: { action: "click->modal#close"}, class: "text-sm font-semibold hover:text-gray-900 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"%>
            <%= f.submit "Create Task", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-5 py-2.5 rounded-lg shadow-sm disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-out transition-all", disabled: @selected_board.blank? %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</turbo-frame>
