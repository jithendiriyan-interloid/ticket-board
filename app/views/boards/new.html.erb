<turbo-frame id="modal">
  <div data-controller="modal" data-modal-target="container" data-action="click->modal#backdropClose" class="fixed inset-0 z-[100] overflow-y-auto bg-slate-900/55 px-4 py-8 sm:px-6">
    <div class="mx-auto mt-8 w-full max-w-lg rounded-2xl bg-white overflow-hidden shadow-xl sm:mt-16">
      <%# Header %>
      <div class="flex items-start justify-between px-6 pt-6">
        <div>
          <p class="text-xs font-medium tracking-widest uppercase  mb-1">New</p>
          <h1 class="text-xl font-medium ">Create board</h1>
        </div>
        <%= button_tag type: "button", data: { action: "click->modal#close" }, class: "flex items-center justify-center w-8 h-8 rounded-full border border-slate-200  hover:bg-slate-100 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
      <%= form_with model: @board do |f| %>
        <div class="px-6 pb-6 mt-5 flex flex-col gap-4">
          <!-- Global Errors (Safeguard) -->
          <% if @board.errors.any? %>
            <div data-turbo-temporary data-controller="flash" class="fixed top-16 right-6 z-50 max-w-md rounded-xl border border-red-200 bg-red-50 p-4 shadow-xl transition-all duration-300" role="alert">
              <div class="flex items-start gap-3">
                <div>
                  <h3 class="text-sm font-medium text-red-800">Please review your submission</h3>
                  <p class="mt-1 text-sm text-red-700"><%= @board.errors.full_messages.to_sentence %></p>
                </div>
              </div>
            </div>
          <% end %>
          <div>
            <%= f.label :name, class: "block text-sm font-medium text-slate-900 mb-1.5" %>
            <%= f.text_field :name, placeholder: "e.g. Sprint 12, Q3 Roadmap…", class: "w-full h-9 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm  placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900" %>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :workspace_id, "Workspace", class: "block text-sm font-medium  mb-1.5" %>
              <%= f.collection_select :workspace_id, @workspaces, :id, :name, { prompt: "Select workspace" }, class: "w-full h-9 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm  focus:outline-none focus:ring-2 focus:ring-slate-900" %>
            </div>
            <div>
              <%= f.label :project_id, "Project", class: "block text-sm font-medium  mb-1.5" %>
              <%= f.collection_select :project_id, @projects, :id, :name, { prompt: "Select project" }, class: "w-full h-9 rounded-lg border border-slate-200 bg-slate-50 px-3 text-sm  focus:outline-none focus:ring-2 focus:ring-slate-900" %>
            </div>
          </div>
          <div class="flex justify-end items-center gap-2 pt-1 border-t border-slate-100">
            <%= button_tag "Cancel", type: "button", data: { action: "click->modal#close" }, class: "h-9 px-4 rounded-lg border border-slate-200 text-sm  hover:bg-slate-100 transition" %>
            <%= f.submit "Create board", disabled: @workspaces.empty? || @projects.empty?, class: "h-9 px-4 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 disabled:opacity-40 disabled:cursor-not-allowed transition" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>