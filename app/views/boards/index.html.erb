<div class="px-4 mt-16">
  <div class="w-[75%] mx-auto">
    <div class="px-4 py-6 bg-transparent rounded-md">
      <div class="mb-7 flex items-center justify-between">
        <h2 class="text-xl font-semibold">Hello, <%= @user.first_name %> </h2>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-4">
        <% @statuses.each do |status| %>
          <div class="bg-gray-50 rounded-xl border border-gray-200 w-60 flex-shrink-0 flex flex-col">
            <!-- Status Header -->
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
              <h3 class="text-sm font-medium text-gray-800 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full inline-block" style="background-color: <%= status_colors[status.name] || '#888780' %>"></span>
                <%= status.name %>
              </h3>
              <span class="text-xs font-mono text-gray-400 bg-white border border-gray-200 rounded-full px-2 py-0.5">
                <%= status.tasks.count %>
              </span>
            </div>
          </div>
        <% end %>
        <%= link_to new_status_path, class: "inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-gray-100 hover:bg-gray-200 border border-gray-200 rounded-md text-sm font-medium text-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Add status
        <% end %>      
        </div>
    </div>
  </div>
</div>