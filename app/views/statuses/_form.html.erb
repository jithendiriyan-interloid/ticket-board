
<%= form_with model: status, class: "space-y-4" do |f| %>
  <% if status.errors.any? %>
    <div class="bg-red-50 text-red-700 text-sm p-3 rounded-lg">
      <% status.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-xs font-medium text-gray-500 mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-300" %>
  </div>

  <div>
    <%= f.label :color, class: "block text-xs font-medium text-gray-500 mb-1" %>
    <%= f.color_field :color, class: "h-9 w-16 rounded border border-gray-200 cursor-pointer" %>
  </div>

  <div>
    <%= f.label :position, class: "block text-xs font-medium text-gray-500 mb-1" %>
    <%= f.number_field :position, min: 1, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :is_default, class: "rounded border-gray-300" %>
    <%= f.label :is_default, "Set as default status", class: "text-sm text-gray-700" %>
  </div>

  <%= f.submit class: "w-full bg-gray-900 text-white text-sm py-2 rounded-lg hover:opacity-85 cursor-pointer" %>
<% end %>