<main class="min-h-screen flex flex-col items-center justify-center">
  <div class="py-4 px-4 md:px-8 ">
    <div class="grid items-center max-w-4xl shadow-md rounded-lg bg-white w-full lg:grid-cols-2">
      <!-- Form -->
      <div class="rounded-lg p-6 max-w-md mx-auto md:p-8 lg:mx-0 ">
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-4">Welcome back!</h1>
          <p class="text-base leading-relaxed">Sign in to your account to access your dashboard and manage your projects.</p>
        </div>
        <%= form_for(resource, as: resource_name, url: session_path(resource_name), data:{form_validation_target: "password", controller: "form-validation", action: "submit->form-validation#validate" }) do |f| %>
          <!-- Email -->
          <div class="mb-4">
            <%= f.label :email, class: "mb-2 font-medium text-sm inline-block" %>
            <%= f.email_field :email, autofocus: true,autocomplete: "email", class: "px-3 h-[35px]  text-sm rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600", placeholder: "Email",
            data:{ form_validation_target: "input", validation_type: "email", validation_required: "true", validation_label: "Email", validation_error_id: "email-error", action: "blur->form-validation#validateField input->form-validation#clearError" } %>
            <span id="email-error" class="hidden text-red-500 text-xs mt-1 block"></span>
          </div>
          <!-- Password -->
          <div class="mb-4">
            <%= f.label :password,class: "mb-2 font-medium text-sm inline-block" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "px-3 h-[35px]  text-sm rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600", placeholder: "Password",
            data:{form_validation_target: "input", validation_type: "password", validation_required: "true", validation_label: "Password", validation_error_id: "password-error", validation_min_length: "6", validation_special_character: "true", action: "blur->form-validation#validateField input->form-validation#clearError" } %>
            <span id="password-error" class="hidden text-red-500 text-xs mt-1 block"></span>
          </div>
          <!-- Remember + Forgot -->
          <div class="flex items-center gap-2 mb-6">
            <div>
              <div class="flex items-start flex-wrap gap-1">
                <label class="flex items-center group>
                  <%= f.check_box :remember_me %>
                  <%= f.label :remember_me, "Remember me", class: "ml-3 text-sm " %>
                </label>
              </div>
            </div>
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "ml-auto text-sm font-medium text-blue-700  hover:underline" %>
          </div>
          <%= f.submit "Log in", class: "w-full py-2 px-3.5 text-sm rounded-md font-semibold cursor-pointer tracking-wide text-white border border-blue-600 bg-blue-600 hover:bg-blue-700 transition-all" %>
          <div class="mt-4 text-sm text-center">Don't have an account?<%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-700 hover:underline ml-1 font-medium " %>
          </div>
          <div class="mt-4 text-sm text-center">Didn't receive unlock instructions?<%= link_to "Click here", new_unlock_path(resource_name), class: "text-blue-700 hover:underline ml-1 font-medium " %>
          </div>
        <% end %>
      </div>
      <!-- Image -->
      <div class="hidden lg:block aspect-[71/50] mx-auto p-6">
        <img src="https://readymadeui.com/images/integration-illus.webp" class="w-full object-cover" alt="login image" />
      </div>
    </div>
  </div>
</main>