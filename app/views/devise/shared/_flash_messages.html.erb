<div class="fixed top-16 right-3 z-50 space-y-3 w-full max-w-sm px-4">
  <% if notice.present? %>
    <div data-controller="flash" class="bg-green-50 text-sm p-3 rounded-md flex gap-3 border border-green-100 max-sm:items-start" role="alert">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <p class="text-green-900 font-medium"> <%= notice %> </p>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div data-controller="flash" class="bg-red-50 text-sm p-3 rounded-md flex gap-3 border border-red-100 max-sm:items-start" role="alert">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <p class="text-red-900 font-medium"> <%= alert %> </p>
      </div>
    </div>
  <% end %>
</div>