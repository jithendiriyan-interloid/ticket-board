<turbo-frame id="modal">
  <div data-controller="modal" data-modal-target="container" data-action="click->modal#backdropClose" class="fixed inset-0 z-[100] overflow-y-auto bg-slate-900/50 px-4 py-8 sm:px-6">
    <div class="mx-auto mt-8 w-[60%] rounded-2xl bg-slate-50 px-4 py-6 shadow-2xl sm:mt-12 sm:px-6">
      <!-- Header -->
      <div class="mb-8 flex items-start justify-between gap-4 border-b border-gray-200 pb-5">
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Edit Workspace</h1>
          <p class="mt-2 text-sm text-gray-500">Update your workspace name and description.</p>
        </div>
        <%= button_tag type: "button", data: { action: "click->modal#close" }, class: "rounded-full p-2 text-slate-500 transition hover:bg-slate-200 hover:text-slate-900" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>
      <!-- Form Container Card -->
      <%= form_with model: @workspace, html: { multipart: true }, data: { turbo_frame: "_top" }, class: "space-y-6" do |f| %>
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-base font-semibold mb-5 pb-3 border-b border-gray-100">Workspace Profile</h2>
          <div class="space-y-5">
            <!-- Workspace Name -->
            <div>
              <%= f.label :name, "Workspace Name", class: "block text-sm font-medium mb-2" %>
              <%= f.text_field :name, placeholder: "e.g., Engineering Team, Marketing Dept", class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
            </div>
            <!-- Workspace Description -->
            <div>
              <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium mb-2" %>
              <%= f.text_area :description, rows: 4, placeholder: "Briefly outline what this workspace will manage...", class: "w-full h-[50px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
            </div>
          </div>
        </div>
        <!-- Action Buttons -->
        <div class="flex items-center justify-end gap-3 pt-2">
          <%= button_tag "Cancel", type: "button", data: { action: "click->modal#close" }, class: "text-sm font-semibold hover:text-gray-900 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors" %>
          <%= f.submit "Save Changes", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-5 py-2.5 rounded-lg shadow-sm transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>