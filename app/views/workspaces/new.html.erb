<div class="w-[50%] mx-auto px-4 sm:px-6 mt-20">
  <!-- Header Section -->
  <div class="mb-8 border-b border-gray-100 pb-5">
    <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Create Workspace</h1>
    <p class="mt-2 text-sm text-gray-500">Workspaces are the highest level of organization, used to group your projects, boards, and team members together.</p>
  </div>
  <!-- Global Errors (Safeguard) -->
  <% if @workspace.errors.any? %>
    <div data-turbo-temporary data-controller="flash" class="fixed top-16 right-6 z-50 max-w-md rounded-xl border border-red-200 bg-red-50 p-4 shadow-xl transition-all duration-300" role="alert">
      <div class="flex items-start gap-3">
        <div>
          <h3 class="text-sm font-medium text-red-800">Please review your submission</h3>
          <p class="mt-1 text-sm text-red-700"><%= @workspace.errors.full_messages.to_sentence %></p>
        </div>
      </div>
    </div>
  <% end %>
  <!-- Form Container Card -->
  <%= form_with model: @workspace, html: { multipart: true }, class: "space-y-6" do |f| %>
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-base font-semibold mb-5 pb-3 border-b border-gray-100">Workspace Profile</h2>
      <div class="space-y-5">
        <!-- Workspace Name -->
        <div>
          <%= f.label :name, "Workspace Name", class: "block text-sm font-medium mb-2" %>
          <%= f.text_field :name, placeholder: "e.g., Engineering Team, Marketing Dept", class: "w-full h-[38px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
        </div>
        <!-- Workspace Description -->
        <div>
          <%= f.label :description, "Description (Optional)", class: "block text-sm font-medium mb-2" %>
          <%= f.text_area :description, rows: 4, placeholder: "Briefly outline what this workspace will manage...", class: "w-full h-[50px] px-2 rounded-lg border-gray-300 shadow-sm focus:outline-blue-600 text-sm" %>
        </div>
      </div>
    </div>
    <!-- Action Buttons -->
    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to "Cancel", :back, class: "text-sm font-semibold hover:text-gray-900 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors" %>
      <%= f.submit "Create Workspace", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-5 py-2.5 rounded-lg shadow-sm transition-all cursor-pointer" %>
    </div>
  <% end %>
</div>