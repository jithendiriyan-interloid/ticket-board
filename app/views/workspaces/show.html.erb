<div class="w-[55%] mx-auto mt-16 px-4">

  <%= link_to workspaces_path, class: "inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-800 mb-5" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
    </svg>
    Back to workspaces
  <% end %>

  <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">

    <%# Header %>
    <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center text-blue-700 font-semibold text-sm">
          <%= @workspace.name.split.map(&:first).first(2).join.upcase %>
        </div>
        <div>
          <p class="text-base font-semibold text-slate-900"><%= @workspace.name %></p>
          <p class="text-xs text-slate-400">Workspace</p>
        </div>
      </div>

      <% if policy(@workspace).edit? %>
        <div class="flex items-center gap-2">
          <%= link_to edit_workspace_path(@workspace),
                data: { turbo_frame: "modal" },
                class: "inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-slate-200 rounded-lg text-slate-700 hover:bg-slate-50 transition" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/>
            </svg>
            Edit
          <% end %>
          <%= link_to workspace_path(@workspace),
                method: :delete,
                data: { turbo_method: :delete, confirm: "Delete this workspace?" },
                class: "inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-red-200 rounded-lg text-red-600 hover:bg-red-50 transition" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
            </svg>
            Delete
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Body %>
    <div class="px-6 py-5 space-y-4">
      <div>
        <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Description</p>
        <p class="text-sm text-slate-700">
          <%= @workspace.description.presence || content_tag(:span, "No description added.", class: "italic text-slate-400") %>
        </p>
      </div>
      <hr class="border-slate-100">
      <div>
        <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Owner</p>
        <p class="text-sm text-slate-700 flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
          </svg>
          <%= @workspace.owner&.first_name || "Unknown" %>
        </p>
      </div>
    </div>

    <%# Footer actions %>
    <div class="px-6 py-4 border-t border-slate-100 flex gap-2">
      <%= link_to new_project_path(workspace_id: @workspace.id),
            class: "inline-flex items-center gap-1.5 text-sm px-3.5 py-1.5 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg text-slate-700 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        New project
      <% end %>
      <%= link_to projects_path,
            class: "inline-flex items-center gap-1.5 text-sm px-3.5 py-1.5 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg text-slate-700 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/>
        </svg>
        View projects
      <% end %>
    </div>

  </div>
</div>